  "shortcuts": [
    {
      "name": "View Quests",
      "short_name": "Quests",
      "description": "Quick access to available quests",
      "url": "/quests",
      "icons": [
        {
          "src": "/icon-quest-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Vocabulary Review",
      "short_name": "Vocab",
      "description": "Quick access to vocabulary review",
      "url": "/vocab",
      "icons": [
        {
          "src": "/icon-vocab-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Achievements",
      "short_name": "Achievements",
      "description": "View achievements and badges",
